#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	rm -rf debian/pi-probe-discord
	install -d debian/pi-probe-discord/opt/pi-probe-discord
	cp -a pi_probe_discord debian/pi-probe-discord/opt/pi-probe-discord/
	install -m 0755 pihole_update_report.py debian/pi-probe-discord/opt/pi-probe-discord/pihole_update_report.py
	install -m 0755 install.py debian/pi-probe-discord/opt/pi-probe-discord/install.py
	install -m 0755 pihole-update-discord.sh debian/pi-probe-discord/opt/pi-probe-discord/pihole-update-discord.sh
	install -d debian/pi-probe-discord/opt/pi-probe-discord/scripts
	cp -a scripts/. debian/pi-probe-discord/opt/pi-probe-discord/scripts/
	install -m 0644 README.md debian/pi-probe-discord/opt/pi-probe-discord/README.md
	install -m 0644 DEPLOYMENT.md debian/pi-probe-discord/opt/pi-probe-discord/DEPLOYMENT.md
	install -m 0644 requirements.txt debian/pi-probe-discord/opt/pi-probe-discord/requirements.txt
	install -d debian/pi-probe-discord/opt/pi-probe-discord/samples
	cp -a samples/. debian/pi-probe-discord/opt/pi-probe-discord/samples/
	install -d debian/pi-probe-discord/usr/bin
	install -m 0755 debian/bin/pi-probe-discord debian/pi-probe-discord/usr/bin/pi-probe-discord
	install -m 0755 debian/bin/pi-probe-discord-install debian/pi-probe-discord/usr/bin/pi-probe-discord-install
	install -m 0755 debian/bin/pi-probe-discord-update debian/pi-probe-discord/usr/bin/pi-probe-discord-update
	install -d debian/pi-probe-discord/usr/share/pi-probe-discord
	install -m 0644 pihole-update-discord.env.example debian/pi-probe-discord/usr/share/pi-probe-discord/pihole-update-discord.env.example
	install -d debian/pi-probe-discord/lib/systemd/system
	install -m 0644 debian/systemd/pi-probe-discord-speedtest.service debian/pi-probe-discord/lib/systemd/system/pi-probe-discord-speedtest.service
	install -m 0644 debian/systemd/pi-probe-discord-speedtest.timer debian/pi-probe-discord/lib/systemd/system/pi-probe-discord-speedtest.timer
	install -m 0644 debian/systemd/pi-probe-discord-full.service debian/pi-probe-discord/lib/systemd/system/pi-probe-discord-full.service
	install -m 0644 debian/systemd/pi-probe-discord-full.timer debian/pi-probe-discord/lib/systemd/system/pi-probe-discord-full.timer

override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start
