# Copy this file to:
#   /etc/pi-probe-discord/pi-probe-discord-bot.env
#
# Required:
# - PI_PROBE_DISCORD_BOT_TOKEN: Discord bot token from the Discord Developer Portal
# - PI_PROBE_DISCORD_ALLOWED_USER_IDS: comma-separated Discord user IDs allowed to use /speedtest

PI_PROBE_DISCORD_BOT_TOKEN="replace-with-bot-token"
PI_PROBE_DISCORD_ALLOWED_USER_IDS="123456789012345678"

# Optional:
# Restrict slash command sync to one guild while testing. Leave empty for global sync.
# PI_PROBE_DISCORD_COMMAND_GUILD_ID="123456789012345678"

# Optional:
# PI_PROBE_DISCORD_BOT_LOG_LEVEL="INFO"
